# === Scouting-Report-Generator Umgebungsvariablen ===
# ANLEITUNG: Benenne diese Datei bei dir lokal zu '.env' um und trage deine Zugangsdaten ein.
# Diese Datei wird von Git ignoriert und niemals hochgeladen.

# 1. Google Gemini API-Key (fuer das KI-Scouting-Fazit)
# Du kannst einen kostenlosen Key unter https://aistudio.google.com/app/apikey generieren.
GEMINI_API_KEY=dein_api_key_hier

# 2. Google E-Mail App-Passwort (fuer den automatisierten PDF-Versand ueber Gmail)
# Dies ist NICHT das normale E-Mail-Passwort, sondern ein generiertes "App-Passwort".
SCOUTING_EMAIL_PW=dein_gmail_app_passwort_hier
